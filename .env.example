# Gold Tier AI Employee — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# === VAULT & TIER ===
VAULT_PATH=C:/Users/user/Gold Tier/Vault
TIER=gold

# === MODE ===
# Set DRY_RUN=true during testing — no emails will be sent
DRY_RUN=true

# === WATCHER INTERVALS (seconds) ===
LINKEDIN_CHECK_INTERVAL=14400   # 4 hours
INSTAGRAM_CHECK_INTERVAL=14400  # 4 hours
NEWS_CHECK_INTERVAL=7200        # 2 hours
FACEBOOK_CHECK_INTERVAL=14400   # 4 hours

# === AI CONTENT GENERATION ===
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# === EMAIL DELIVERY (SMTP) ===
# Use a Gmail App Password (not your main password)
# Generate at: Google Account → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
REVIEWER_EMAIL=your-review-email@gmail.com

# === LINKEDIN API (for future auto-posting) ===
# Get credentials from: https://www.linkedin.com/developers/apps
# Requires w_member_social OAuth scope
# NOTE: LINKEDIN_CLIENT_ID and LINKEDIN_CLIENT_SECRET are not yet used — linkedin_post.py is a stub
LINKEDIN_ACCESS_TOKEN=your-access-token-here
LINKEDIN_AUTHOR_URN=urn:li:person:your-person-id-here

# === FACEBOOK PAGE API (Gold Tier — auto-posting) ===
# Get from: Meta for Developers -> Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
# Generate a long-lived Page Access Token (valid ~60 days)
FB_PAGE_ID=your-facebook-page-id-here
FB_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token-here
# Set to true to auto-post verified Facebook drafts without human approval
AUTO_POST_FACEBOOK=false

# === INSTAGRAM GRAPH API (Gold Tier — auto-posting) ===
# Link Instagram Business Account to a Facebook Page first
# Same access token as FB if accounts are linked
# Required permissions: instagram_basic, instagram_content_publish
# Get IG_USER_ID: GET /me?fields=id,username&access_token=<token> on the IG account
IG_USER_ID=your-instagram-business-user-id-here
IG_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token-here
# A publicly accessible HTTPS image URL — required by Instagram Graph API for all posts
IG_DEFAULT_IMAGE_URL=https://your-site.com/images/default_post.jpg
AUTO_POST_INSTAGRAM=false

# === TWITTER / X API (Gold Tier — auto-posting) ===
# Get from: developer.twitter.com -> Project -> App -> Keys and Tokens
# Set App Permissions to "Read and Write" before generating tokens
# Free tier: 1,500 tweets/month
TWITTER_API_KEY=your-api-key-here
TWITTER_API_SECRET=your-api-secret-here
TWITTER_ACCESS_TOKEN=your-access-token-here
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret-here
TWITTER_BEARER_TOKEN=your-bearer-token-here
TWITTER_CHECK_INTERVAL=14400
AUTO_POST_TWITTER=false

# === ODOO COMMUNITY (Gold Tier — content strategy tracking) ===
# NOT for accounting — used to track content posts, drafts, and engagement per platform
# Install Odoo Community 19+ locally, install the "Project" module
# Generate API key: Odoo -> Settings -> Technical -> API Keys
ODOO_URL=http://localhost:8069
ODOO_DB=your-odoo-database-name
ODOO_USERNAME=admin@yourcompany.com
ODOO_API_KEY=your-odoo-api-key-here

# === GMAIL WATCHER (Gold Tier — personal inbox monitoring) ===
# STATUS: STRUCTURE READY — requires Gmail API OAuth2 setup
# Setup: console.cloud.google.com → enable Gmail API → create OAuth2 Desktop credentials
# Download credentials JSON → save to Watchers/gmail_credentials.json
# Run gmail_watcher.py once manually to complete browser auth (generates gmail_token.json)
GMAIL_CREDENTIALS_FILE=C:/Users/user/Gold Tier/Watchers/gmail_credentials.json
GMAIL_TOKEN_FILE=C:/Users/user/Gold Tier/Watchers/gmail_token.json
GMAIL_CHECK_INTERVAL=300
GMAIL_MAX_RESULTS=10

# === SAFETY CAPS ===
MAX_DRAFTS_PER_RUN=1
